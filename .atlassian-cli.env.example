# Server / Data Center example
JIRA_URL="https://jira.example.com"
JIRA_PERSONAL_TOKEN="your-jira-token"
JIRA_SSL_VERIFY="true"

CONFLUENCE_URL="https://wiki.example.com"
CONFLUENCE_PERSONAL_TOKEN="your-confluence-token"
CONFLUENCE_SSL_VERIFY="true"

# Optional aliases supported by cli-atlassian
# JIRA_TOKEN="your-jira-token"
# CONFLUENCE_TOKEN="your-confluence-token"

# Cloud-style fields can also be added if your environment needs them
# JIRA_USERNAME="user@example.com"
# CONFLUENCE_USERNAME="user@example.com"
