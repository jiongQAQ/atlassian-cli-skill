# Cloud example
# Get the base URLs from your browser address bar.
# Create API tokens from your Atlassian account security page:
# https://support.atlassian.com/atlassian-account/docs/manage-api-tokens-for-your-atlassian-account/
#
# JIRA_URL="https://your-domain.atlassian.net"
# JIRA_USERNAME="your.email@example.com"
# JIRA_API_TOKEN="your-cloud-api-token"
#
# CONFLUENCE_URL="https://your-domain.atlassian.net/wiki"
# CONFLUENCE_USERNAME="your.email@example.com"
# CONFLUENCE_API_TOKEN="your-cloud-api-token"

# Server / Data Center example
# Get the base URLs from your browser address bar.
# Get the personal access tokens from each product's personal settings /
# avatar menu under "Personal access tokens". If the menu does not exist,
# ask your administrator whether PAT is enabled on the instance.
JIRA_URL="https://jira.example.com"
JIRA_PERSONAL_TOKEN="your-jira-personal-token"
JIRA_SSL_VERIFY="true"

CONFLUENCE_URL="https://wiki.example.com"
CONFLUENCE_PERSONAL_TOKEN="your-confluence-personal-token"
CONFLUENCE_SSL_VERIFY="true"

# Optional aliases supported by cli-atlassian
# JIRA_TOKEN="your-cloud-api-token"
# CONFLUENCE_TOKEN="your-cloud-api-token"
